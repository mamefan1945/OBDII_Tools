<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OBDIITools" parent="android:Theme.DeviceDefault.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.OBDIITools.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#080810</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash</item>
        <item name="windowSplashScreenIconBackgroundColor">#0D0D1A</item>
        <item name="postSplashScreenTheme">@style/Theme.OBDIITools</item>
    </style>
</resources>
